{
  "name": "contabo-storage-manager",
  "version": "1.0.0",
  "description": "Lightweight FTP bridge / storage manager for Contabo VPS",
  "private": true,
  "scripts": {
    "start:node": "cd packages/node-bridge && node src/index.js",
    "dev:node": "cd packages/node-bridge && node --watch src/index.js",
    "install:node": "cd packages/node-bridge && npm install",
    "list-ftp": "node scripts/listFtpFiles.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
