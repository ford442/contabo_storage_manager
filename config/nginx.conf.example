# Nginx reverse proxy example for FTP Bridge services
# Place in /etc/nginx/sites-available/ftpbridge and symlink to sites-enabled

server {
    listen 80;
    server_name your-vps-domain.com;  # Replace with your domain or IP

    # Redirect HTTP → HTTPS (uncomment when cert is ready)
    # return 301 https://$host$request_uri;

    # Python Bridge (FastAPI on port 8000)
    location /py/ {
        proxy_pass         http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # Node Bridge (Express on port 3000)
    location /node/ {
        proxy_pass         http://127.0.0.1:3000/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
