# ── General ──────────────────────────────────────────────────────────────────
APP_ENV=production          # development | production

# ── FTP / vsftpd (already running on VPS) ────────────────────────────────────
FTP_HOST=127.0.0.1
FTP_PORT=21
FTP_USER=ftpbridge
FTP_PASS=changeme
FTP_UPLOAD_DIR=/home/ftpbridge/files
FTP_PASSIVE_MIN=40000
FTP_PASSIVE_MAX=40100
FTP_TLS=false               # true to enable FTPS (requires cert on host)

EXTERNAL_FTP_HOST=storage.1ink.us
EXTERNAL_FTP_USER=storage_manager
EXTERNAL_FTP_PASS=storage442
EXTERNAL_FTP_PORT=22
EXTERNAL_FTP_DIR=/home/storage_manager

# ── Webhook security ──────────────────────────────────────────────────────────
WEBHOOK_SECRET=xyxyxyxy123321xyxyxyxy
# Algorithm used to verify HMAC signatures: sha256 | sha1
WEBHOOK_HMAC_ALGO=sha256

# ── Python Bridge (FastAPI) ───────────────────────────────────────────────────
PYTHON_HOST=0.0.0.0
PYTHON_PORT=8000
PYTHON_WORKERS=2
# Comma-separated list of allowed CORS origins (* for any)
CORS_ORIGINS=*
# Regex fallback for trusted browser origins when exact entries are stale
CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)?(1ink\.us|noahcohn\.com)$|^http://(localhost|127\.0\.0\.1)(:\d+)?$

# ── Node Bridge (Express) ─────────────────────────────────────────────────────
NODE_HOST=0.0.0.0
NODE_PORT=3000
NODE_ENV=production

# ── Storage ──────────────────────────────────────────────────────────────────
# Host path mounted into both containers (must match vsftpd serve path)
FILES_DIR=/home/ftpbridge/files

# Public base URL that browsers use to load stored files.
# Set this to your domain once TLS is configured in front of nginx-files.
# Used to construct download links in webhook responses.
STATIC_BASE_URL=https://storage.1ink.us

# Maximum allowed upload size in megabytes (enforced per upload in Python bridge)
MAX_UPLOAD_MB=8192

# Port exposed by the nginx-files static server container (HTTP, no TLS)
# Put Caddy / Nginx / Traefik with a real cert in front of this.
NGINX_PORT=8080

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info              # debug | info | warning | error
LOG_FILE=/var/log/ftpbridge/app.log

# ── Optional: external API polling ───────────────────────────────────────────
POLL_INTERVAL_SECONDS=60
EXTERNAL_API_URL=https://api.example.com
EXTERNAL_API_KEY=your-api-key-here

# ── Optional: external FLAC Player backend ───────────────────────────────────
# When set, the storage manager will POST metadata for every uploaded audio
# file to this URL immediately after the file lands on disk.
# Example: https://storage.noahcohn.com/api/upload/songs
FLAC_PLAYER_API_URL=
